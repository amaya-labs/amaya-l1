# Amaya L1 — non-secret environment placeholders
#
# Copy to `.env` for local operator convenience if needed.
# WARNING: `.env` must NEVER contain wallet private keys, recovery phrases,
# validator staking keys, TLS private keys, or production credentials.
#
# TAMAYA is a valueless testnet asset used only for gas and network testing.
#
# Fill public identifiers ONLY after approved deployment, using values from
# successful deployment output. Do NOT invent or hard-code AMAYA_RPC_URL as
# http://127.0.0.1:9650 — port 9650 is commonly a Primary Network/API port,
# not the guaranteed Amaya L1 RPC. Local Alpha RPC is localhost-only and
# typically uses a dynamically assigned port.

AMAYA_ENV=local-alpha
AMAYA_NETWORK_NAME="Amaya Local Alpha"
AMAYA_TOKEN_SYMBOL=TAMAYA

# Public identifiers — leave empty until deliberate create/deploy records them.
AMAYA_SUBNET_L1_ID=
AMAYA_BLOCKCHAIN_ID=
AMAYA_EVM_CHAIN_ID=
AMAYA_RPC_URL=
AMAYA_VALIDATOR_NODE_ID=
